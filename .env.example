# Copy to .env.local for local dev. GitHub Actions uses repo secrets with the same names.
ANTHROPIC_API_KEY=sk-ant-...
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/nachrichten-ueberblick
STUDENT_NAME=Pau
# Optional override for the public PDF URL pattern (used when posting to n8n).
# {date} is replaced with YYYY-MM-DD.
PDF_URL_TEMPLATE=https://raw.githubusercontent.com/USER/nachrichten-ueberblick/main/output/{date}.pdf
